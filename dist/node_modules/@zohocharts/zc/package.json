{
    "name": "@zohocharts/zc",
    "version": "1.9.5",
    "zcversion": "2.36",
    "description": "Charting library for Zoho built over d3.js",
    "repository": {
        "type": "git",
        "url": "https://git.csez.zohocorpin.com/opensource/zohocharts.git"
    },
    "publishConfig": {
        "registry": "http://cm-npmregistry/"
    },
    "files": [
        "dist/zc.js",
        "dist/zc.js.map",
        "dist/zc.min.js",
        "dist/zc.node.js",
        "src/**/*.js",
        "index.js",
        "gulpfile-fconcat.js",
        "package.json",
        "rollup.config.js",
        "rollup.node.js",
        "module-config.json",
        "module-picker.js",
        "module-reference.json",
        "babel.config.json",
        ".babelrc",
        ".jshintrc",
        "deps/*.js",
        "js_list/**/*.txt"
    ],
    "browser": "dist/zc.js",
    "main": "dist/zc.node.js",
    "unpkg": "dist/zc.min.js",
    "jsdelivr": "dist/zc.min.js",
    "module": "index.js",
    "scripts": {
        "prepublishOnly": "rimraf src && mkdir src && cp -r ./../../../../webapps/src/zcjs/* ./src && rimraf deps && mkdir deps && cp ./../../../d3-custom/d3.js ./deps && cp ./../../../d3-custom/babel-polyfill.js ./deps",
        "build": "gulp --gulpfile gulpfile-fconcat.js && rimraf dist && mkdir dist && rollup -c --bundleConfigAsCjs && node rollup.node && cd dist && terser zc.js -c -m -o zc.es6.min.js && babel --root-mode upward --source-maps=false zc.js -o zc.js && uglifyjs zc.js -c -m -o zc.min.js && cp zc.min.js zc.es5.min.js",
        "prepare": "npm run prepublishOnly && npm run build"
    },
    "dependencies": {
        "@zohocharts/d3": "3.0.0"
    },
    "devDependencies": {
        "@babel/cli": "7.18.10",
        "@babel/core": "7.24.7",
        "@babel/node": "7.18.10",
        "@babel/plugin-proposal-class-properties": "7.18.6",
        "@babel/plugin-proposal-object-rest-spread": "7.18.9",
        "@babel/plugin-proposal-private-methods": "7.18.6",
        "@babel/plugin-transform-spread": "7.18.9",
        "@babel/preset-env": "7.24.7",
        "@babel/traverse": "7.18.13",
        "@rollup/plugin-babel": "6.0.4",
        "@rollup/plugin-commonjs": "25.0.7",
        "@rollup/plugin-node-resolve": "15.2.3",
        "babel-loader": "9.2.1",
        "eslint": "4.18.0",
        "eslint-config-standard": "11.0.0",
        "eslint-plugin-import": "2.12.0",
        "eslint-plugin-node": "6.0.1",
        "eslint-plugin-promise": "3.8.0",
        "eslint-plugin-standard": "3.1.0",
        "gulp": "4.0.2",
        "gulp-concat": "2.6.1",
        "lerna": "3.13.0",
        "map-stream": "0.0.7",
        "rimraf": "2.6.3",
        "rollup": "4.18.0",
        "rollup-plugin-node-resolve": "2",
        "terser": "5.31.1",
        "webpack": "5.95.0",
        "webpack-cli": "5.1.4",
        "webpack-dev-server": "5.1.0"
    },
    "gitHead": "f6ee9d966c95084f24536790e4d0591aa2c38a1f"
}
