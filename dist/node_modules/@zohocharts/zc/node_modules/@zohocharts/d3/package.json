{
  "name": "@zohocharts/d3",
  "version": "3.0.0",
  "description": "D3 js Custom bundle for Zoho Charts",
  "repository": {
    "type": "git",
    "url": "https://git.csez.zohocorpin.com/opensource/zohocharts.git"
  },
  "publishConfig": {
    "registry": "http://cm-npmregistry/"
  },
  "files": [
    "d3.js",
    "d3.min.js",
    "index.js",
    "package.json"
  ],
  "main": "d3.js",
  "browser": "d3.js",
  "unpkg": "d3.min.js",
  "jsdelivr": "d3.min.js",
  "module": "index.js",
  "scripts": {
    "audit": "npm audit --omit=dev --registry=https://registry.npmjs.org/",
    "clean": "rm -r node_modules package-lock.json",
    "preinstall": "npm -v && node -v",
    "prepare": "patch-package && rollup -c --bundleConfigAsCjs && babel d3.js -o d3.js && uglifyjs d3.js -c -m -o d3.min.js"
  },
  "dependencies": {
    "@zohocharts/d3-selection-multi": "1.0.1",
    "d3-array": "1.2.1",
    "d3-axis": "1.0.8",
    "d3-brush": "3.0.0",
    "d3-collection": "1.0.4",
    "d3-color": "3.1.0",
    "d3-dispatch": "1.0.3",
    "d3-drag": "3.0.0",
    "d3-dsv": "1.0.8",
    "d3-ease": "1.0.3",
    "d3-format": "1.2.1",
    "d3-geo": "1.11.1",
    "d3-geo-projection": "2.4.1",
    "d3-hierarchy": "3.1.2",
    "d3-interpolate": "3.0.1",
    "d3-path": "1.0.5",
    "d3-polygon": "1.0.5",
    "d3-quadtree": "1.0.6",
    "d3-request": "1.0.6",
    "d3-scale": "4.0.2",
    "d3-selection": "3.0.0",
    "d3-shape": "1.2.0",
    "d3-time": "1.0.8",
    "d3-time-format": "2.1.1",
    "d3-timer": "1.0.7",
    "d3-transition": "3.0.1",
    "d3-zoom": "3.0.0",
    "topojson-client": "3.0.0",
    "versor": "0.0.4"
  },
  "devDependencies": {
    "@babel/cli": "7.18.10",
    "@babel/core": "7.18.13",
    "@babel/plugin-proposal-object-rest-spread": "7.18.9",
    "@babel/plugin-transform-modules-umd": "7.18.6",
    "@babel/plugin-transform-spread": "7.18.9",
    "@babel/preset-env": "7.20.2",
    "babel-loader": "7.1.5",
    "patch-package": "^8.0.0",
    "rollup": "4.22.4",
    "rollup-plugin-node-resolve": "2",
    "uglify-js": "2"
  },
  "//": [
    "M2.35: When updating d3 related packages for vulnerability issue fix, d3-selection@3 and d3-selection-multi@1 having issues with binding attrs and styles API to selection prototype. It is caused due to a d3-selection@1 version dependency inside d3-selection-multi@1 package.json. So, we need to override d3-selection@1 to @3 for binding the d3-selection-multi API to d3-selection@3."
  ]
}
